*.jsonl
debug/
cache/
telemetry/
session-env/
*.log
.DS_Store

# Scratch/working dirs — never committed. tmp/ holds god-review findings,
# pre-compact briefs, ready-plans, etc. that often contain fixture strings
# tripping the secret-scan and shouldn't be auto-pushed anyway.
tmp/

# Secrets — never commit
.env
.env.*
!.env.example
credentials.md
credentials.local.md
# R3 D5: glob covers CLAUDE.local.md (alias), CLAUDE.local.<sid8>.md (SID-tagged primary),
# CLAUDE.local.md.prev (snapshot), and future .tmp variants.
# Pattern: CLAUDE.local*.md* — wildcard after .local covers SID8 segment; trailing * covers
# .prev suffix on the alias. Matches: CLAUDE.local.md, CLAUDE.local.18d1779a.md,
# CLAUDE.local.md.prev. The original **/CLAUDE.local.md* did NOT match SID-tagged files.
**/CLAUDE.local*.md*

# Common secret-bearing files (defense in depth)
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
.ssh/
.aws/credentials
.aws/config
.gcp/
*.credentials.json
*service-account*.json
*-key.json
.netrc
.npmrc.local
.pypirc

# Editor / OS swap files that may contain partial buffer contents
*.swp
*.swo
*~
.#*

# Mac mini CRD skill — built Go binaries (not committed)
skills/macmini/server/dist/
skills/macmini/client/dist/

# Codex bridge — generated locally from commands/ and skills/
codex/generated/
