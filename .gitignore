*.jsonl
debug/
cache/
telemetry/
session-env/
*.log
.DS_Store

# Scratch/working dirs — never committed. tmp/ holds god-review findings,
# pre-compact briefs, ready-plans, etc. that often contain fixture strings
# tripping the secret-scan and shouldn't be auto-pushed anyway.
tmp/

# Secrets — never commit
.env
.env.*
!.env.example
credentials.md
credentials.local.md
**/CLAUDE.local.md

# Common secret-bearing files (defense in depth)
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
.ssh/
.aws/credentials
.aws/config
.gcp/
*.credentials.json
*service-account*.json
*-key.json
.netrc
.npmrc.local
.pypirc

# Editor / OS swap files that may contain partial buffer contents
*.swp
*.swo
*~
.#*

# Mac mini CRD skill — built Go binaries (not committed)
skills/macmini/server/dist/
skills/macmini/client/dist/
