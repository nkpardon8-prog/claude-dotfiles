{
  "_template_note": "Copy this file to ~/.claude/settings.json on each machine. ~/.claude/settings.json is per-machine and not tracked in this dotfiles repo. Re-run on every fresh setup.",
  "_security_note": "Removed from auto-allow vs prior baselines: mcp__supabase__apply_migration / execute_sql (no silent DB mutations), Bash(node :*) / Bash(node -e :*) / Bash(python -c :*) / Bash(python3 -c :*) (no arbitrary code execution via runtime -e/-c flags), and Bash(curl -s :*) / Bash(curl -fsS :*) (no unattended network egress). This template still auto-allows pip install / npm install AND sets skipDangerousModePermissionPrompt + skipAutoPermissionPrompt to true, which only makes sense on a personal dev machine the operator fully trusts. Before copying to a shared machine, a CI runner, or any environment that should not auto-approve arbitrary package installs, REVIEW the Bash allow-list and the two skip* keys and remove anything you do not want auto-approved.",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm run build)",
      "Bash(npm run build:*)",
      "Bash(npm run dev)",
      "Bash(npm run dev:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck:*)",
      "Bash(npm ls --depth=0)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx vite --port :*)",
      "Bash(python -m py_compile :*)",
      "Bash(python3 -m py_compile :*)",
      "Bash(python -m pytest :*)",
      "Bash(python3 -m pytest :*)",
      "Bash(pip install :*)",
      "Bash(pip install postgrest)",
      "Bash(pip install pytest-asyncio)",
      "Bash(open :*)",
      "Bash(lsof :*)",
      "Bash(fgrep :*)",
      "mcp__supabase__list_branches",
      "mcp__supabase__list_tables",
      "mcp__supabase__search_docs",
      "mcp__supabase__get_logs",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/.claude-dotfiles && git pull --ff-only 2>/dev/null; if [ -f ~/.config/claude/credentials.md ] && grep -nIE '(sk-(ant|proj|svcacct)?-?[A-Za-z0-9_-]{20,}|AIza[0-9A-Za-z_-]{35}|ghp_[A-Za-z0-9]{36,}|gho_[A-Za-z0-9]{36,}|ghu_[A-Za-z0-9]{36,}|ghs_[A-Za-z0-9]{36,}|ghr_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{40,}|AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|xox[abposr]-[A-Za-z0-9-]{10,}|hf_[A-Za-z0-9]{30,}|ya29\\.[A-Za-z0-9_-]{20,}|whsec_[A-Za-z0-9]{20,}|(rk|sk|pk)_(live|test)_[A-Za-z0-9]{20,}|-----BEGIN +(RSA +|OPENSSH +)?PRIVATE +KEY-----)' ~/.config/claude/credentials.md 2>/dev/null; then echo 'WARNING: possible secret value detected in ~/.config/claude/credentials.md \u2014 should be op:// references only. Rotate the leaked secret at the provider.' >&2; fi; true",
            "timeout": 10,
            "statusMessage": "Syncing dotfiles..."
          },
          {
            "type": "command",
            "command": "$HOME/.claude-dotfiles/scripts/progress/on-session-start-cleanup.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude-dotfiles/scripts/progress/on-prompt-submit.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude-dotfiles/scripts/dotfiles-sync.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude-dotfiles/scripts/progress/on-todo-write.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude-dotfiles/scripts/progress/on-task-spawn.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "^(Edit|MultiEdit|Write|NotebookEdit|Read|Bash|Grep|Glob|WebFetch|WebSearch|Task|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude-dotfiles/scripts/progress/on-tool-activity.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude-dotfiles/scripts/progress/on-stop.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
